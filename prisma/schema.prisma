generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------------
// Enums & Types
// ------------------------------------------------------------

enum UserRole {
  HR_ADMIN
  HR_STAFF
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  TERMINATED
  RESIGNED
  ON_LEAVE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Invitation {
  id           String           @id @default(uuid())
  senderId     String
  tenantId     String
  departmentId String?
  email        String
  token        String           @unique
  status       InvitationStatus @default(PENDING)
  positionId   String?
  expiresAt    DateTime
  role         UserRole         @default(EMPLOYEE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  sender       User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position     Position?        @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([email])
  @@index([role])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum CalculationMethod {
  FIXED
  PERCENTAGE
  CONDITIONAL
}

enum RuleType {
  ALLOWANCE
  DEDUCTION
}

enum PayPeriodStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CLOSED
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

enum ActionEnum {
  CREATE
  TERMINATE
  REACTIVATE
  ADD_ALLOWANCE
  REMOVE_ALLOWANCE
  ADD_DEDUCTION
  REMOVE_DEDUCTION
  START_PAYROLL_RUN
  PROCESS
  PAUSE
  RESUME
  ARCHIVE
  RESTORE
  UPDATE
  DELETE
  VIEW
  OTHER
}

// ------------------------------------------------------------
// Authentication & Employee Information Management
// ------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  address   String?
  phone     String?
  email     String?
  website   String?

  users            User[]
  departments      Department[]
  positions        Position[]
  salaryStructures SalaryStructure[]
  allowanceTypes   AllowanceType[]
  deductionTypes   DeductionType[]
  payPeriods       PayPeriod[]
  payrollRuns      PayrollRun[]
  calculationRules CalculationRule[]
  auditLogs        AuditLog[]
  invitations      Invitation[]

  @@index([phone])
  @@index([email])
  @@index([website])
}

model Department {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Manager relation
  managerId String?
  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)

  // Department fields
  code        String?
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Reverse relations
  employees   User[]
  positions   Position[]
  invitations Invitation[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
}

model Position {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Department relation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Position fields
  code      String?
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Reverse relations
  employees   User[]
  invitations Invitation[]

  @@unique([tenantId, title])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, departmentId])
}

model User {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Department relation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Position relation
  positionId String?
  position   Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  // Creator relation (for employee creation tracking)
  createdBy     String?
  createdByUser User?   @relation("UserCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdUsers  User[]  @relation("UserCreator")

  // Managed departments
  managedDepartments Department[]      @relation("DepartmentManager")
  salaryStructures   SalaryStructure[]
  processedPayrolls  PayrollRun[]      @relation("PayrollRunProcessor")
  payslips           Payslip[]

  // Authentication fields
  email         String
  password      String? // Better Auth - password (nullable, required for email/password auth)
  name          String? // Better Auth - display name (optional, can map to firstName)
  emailVerified DateTime? // Better Auth - email verification timestamp (required for email verification)
  image         String? // Better Auth - profile image URL (optional, can map to avatarUrl)
  role          UserRole  @default(EMPLOYEE)
  isDeleted     Boolean   @default(false)
  lastLogin     DateTime?

  // Employee fields (optional - not all users are employees)
  employeeId       String
  gender           Gender?         @default(PREFER_NOT_TO_SAY)
  phone            String?
  hireDate         DateTime?
  address          String?
  emergencyContact String?
  status           EmployeeStatus? @default(ACTIVE)
  employmentType   EmploymentType? @default(FULL_TIME)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions    Session[]
  accounts    Account[]
  auditLogs   AuditLog[]
  invitations Invitation[]

  @@unique([tenantId, email])
  @@unique([tenantId, employeeId])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, positionId])
  @@index([tenantId, status])
  @@index([email])
  @@index([role])
  @@index([isDeleted])
  @@index([status])
  @@map("User")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ------------------------------------------------------------
// Payroll & Benefits Management
// ------------------------------------------------------------

model SalaryStructure {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Salary fields
  baseSalary    Float     @default(0)
  grossSalary   Float     @default(0)
  effectiveDate DateTime
  endDate       DateTime?
  currency      String    @default("USD")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Reverse relations
  allowances Allowance[]
  deductions Deduction[]

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([userId, effectiveDate])
}

model AllowanceType {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  code        String
  description String?
  isTaxable   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  allowances       Allowance[]
  calculationRules CalculationRule[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
}

model Allowance {
  id String @id @default(uuid())

  // Salary Structure relation
  salaryStructureId String
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  // Allowance type relation
  allowanceTypeId String
  allowanceType   AllowanceType @relation(fields: [allowanceTypeId], references: [id], onDelete: Restrict)

  amount            Float             @default(0)
  calculationMethod CalculationMethod @default(FIXED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([salaryStructureId])
  @@index([allowanceTypeId])
}

model DeductionType {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  code        String
  description String?
  isStatutory Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  deductions       Deduction[]
  calculationRules CalculationRule[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
}

model Deduction {
  id String @id @default(uuid())

  // Salary Structure relation
  salaryStructureId String
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  // Deduction type relation
  deductionTypeId String
  deductionType   DeductionType @relation(fields: [deductionTypeId], references: [id], onDelete: Restrict)

  amount            Float             @default(0)
  calculationMethod CalculationMethod @default(FIXED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([salaryStructureId])
  @@index([deductionTypeId])
}

model CalculationRule {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Rule identification
  name        String
  description String?

  // Rule type and target
  ruleType        RuleType
  allowanceTypeId String?
  allowanceType   AllowanceType? @relation(fields: [allowanceTypeId], references: [id], onDelete: Restrict)
  deductionTypeId String?
  deductionType   DeductionType? @relation(fields: [deductionTypeId], references: [id], onDelete: Restrict)

  // Rule conditions (JSONB)
  conditions Json // Stores condition tree: {operator: "AND"|"OR", conditions: [...]}

  // Rule action (JSONB)
  action Json // Stores action: {type: "FIXED"|"PERCENTAGE"|"FORMULA", value: number, base: "baseSalary"|"grossSalary"}

  // Rule priority (higher = evaluated first)
  priority Int @default(0)

  // Rule status
  isActive Boolean @default(true)

  // Rule validity period
  effectiveDate DateTime
  endDate       DateTime?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, ruleType])
  @@index([allowanceTypeId])
  @@index([deductionTypeId])
}

model PayPeriod {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  periodName    String
  startDate     DateTime
  endDate       DateTime
  calendarMonth Int
  calendarYear  Int
  status        PayPeriodStatus @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  payrollRuns PayrollRun[]

  @@unique([tenantId, periodName])
  @@unique([tenantId, calendarYear, calendarMonth])
  @@index([tenantId])
}

model PayrollRun {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Pay period relation
  payPeriodId String
  payPeriod   PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Restrict)

  runDate         DateTime         @default(now())
  totalEmployees  Int              @default(0)
  totalGrossPay   Float            @default(0)
  totalDeductions Float            @default(0)
  totalNetPay     Float            @default(0)
  status          PayrollRunStatus @default(DRAFT)
  processedBy     String?
  processedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  processor User?            @relation("PayrollRunProcessor", fields: [processedBy], references: [id], onDelete: SetNull)
  payslips  Payslip[]
  progress  PayrollProgress?

  @@index([tenantId])
  @@index([tenantId, payPeriodId])
  @@index([status, runDate])
}

model Payslip {
  id String @id @default(uuid())

  // Payroll run relation
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  grossSalary     Float    @default(0)
  totalAllowances Float    @default(0)
  totalDeductions Float    @default(0)
  netSalary       Float    @default(0)
  filePath        String?
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([payrollRunId, userId])
  @@index([payrollRunId])
  @@index([userId])
}

model PayrollProgress {
  id                    String     @id @default(uuid())
  payrollRunId          String     @unique
  payrollRun            PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  totalEmployees        Int        @default(0)
  completedEmployees    Int        @default(0)
  failedEmployees       Int        @default(0)
  startedAt             DateTime   @default(now())
  estimatedCompletionAt DateTime?
  lastUpdatedAt         DateTime   @updatedAt

  @@index([payrollRunId])
}

// ------------------------------------------------------------
// Audit Trail Management and Notification System
// ------------------------------------------------------------

model AuditLog {
  id         String     @id @default(uuid())
  userId     String
  tenantId   String
  timestamp  DateTime   @default(now())
  action     ActionEnum
  entityType String
  entityId   String
  changes    Json?
  ipAddress  String?
  userAgent  String?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityId, entityType])
  @@index([timestamp])
}
