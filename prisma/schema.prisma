generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------------
// Enums & Types
// ------------------------------------------------------------

enum UserRole {
  HR_ADMIN
  HR_STAFF
  STAFF
  DEPARTMENT_ADMIN
  SUPER_ADMIN
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum EmployeeStatus {
  INACTIVE
  ACTIVE
  ON_LEAVE
}

enum TerminationReason {
  FIRED
  RESIGNED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum WorkLocation {
  ONSITE
  HYBRID
  REMOTE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum SalaryPeriodType {
  MONTHLY
  ANNUAL
}

enum GambiaSsnFundingMode {
  DEDUCT_FROM_EMPLOYEE
  EMPLOYER_PAYS_ON_BEHALF
}

model Invitation {
  id                  String            @id @default(uuid())
  senderId            String
  tenantId            String
  departmentId        String?
  email               String
  token               String            @unique
  status              InvitationStatus  @default(PENDING)
  positionId          String?
  expiresAt           DateTime
  role                UserRole          @default(STAFF)
  // User fields (applied on accept)
  dateOfBirth         DateTime?
  hireDate            DateTime?
  employmentStatus    EmployeeStatus?
  employmentType      EmploymentType?
  // Compensation (creates SalaryStructure on accept when baseSalary is set)
  baseSalary          Float?
  salaryPeriodType    SalaryPeriodType? @default(MONTHLY)
  salaryEffectiveDate DateTime?
  salaryCurrency      String?           @default("USD")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  sender              User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department          Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position            Position?         @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([email])
  @@index([role])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum CalculationMethod {
  FIXED
  PERCENTAGE
  FORMULA
}

enum RuleType {
  ALLOWANCE
  DEDUCTION
}

enum PayScheduleFrequency {
  SEMI_MONTHLY
  BI_WEEKLY
  MONTHLY
  WEEKLY
}

enum PayPeriodStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CLOSED
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

enum ActionEnum {
  CREATE
  TERMINATE
  REACTIVATE
  ACTIVATE
  DEACTIVATE
  ADD_ALLOWANCE
  REMOVE_ALLOWANCE
  ADD_DEDUCTION
  REMOVE_DEDUCTION
  START_PAYROLL_RUN
  PROCESS
  PAUSE
  RESUME
  ARCHIVE
  RESTORE
  UPDATE
  DELETE
  VIEW
  DOWNLOAD
  EXPORT
  DISTRIBUTE
  OTHER
}

enum HolidayType {
  PUBLIC // National/public holiday
  COMPANY // Company-specific holiday
  REGIONAL // Regional holiday (state/province)
  RELIGIOUS // Religious holiday
  OPTIONAL // Optional holiday (employee choice)
}

enum AccrualMethod {
  FRONT_LOADED // All days available at year start
  ACCRUAL // Days accrue over time
}

enum AccrualFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum CarryoverType {
  NONE // No carryover allowed
  FULL // Carry all unused balance
  LIMITED // Carry up to maxCarryoverDays
  ENCASHMENT // Sell unused days (paid out)
}

enum LeaveRequestStatus {
  PENDING // Awaiting manager approval
  MANAGER_APPROVED // Manager approved, awaiting HR
  APPROVED // Fully approved (HR approved)
  REJECTED // Rejected by manager or HR
  CANCELLED // Cancelled by employee
}

enum BatchJobType {
  EMPLOYEE_CREATION
  EMPLOYEE_INVITATION
  ALLOWANCE_ALLOCATION
  DEDUCTION_ALLOCATION
  BULK_UPDATE
}

enum BatchJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BatchJobRowStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

// ------------------------------------------------------------
// Authentication & Employee Information Management
// ------------------------------------------------------------

model Tenant {
  id           String       @id @default(uuid())
  code         String
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  status       TenantStatus @default(ACTIVE)
  address      String?
  addressLine1 String?
  addressLine2 String?
  phone        String?
  email        String?
  website      String?

  // Weekend configuration: array of day numbers (0=Sunday, 6=Saturday)
  // Default: [0, 6] for Saturday/Sunday weekends
  // Middle East example: [5, 6] for Friday/Saturday weekends
  weekendDays Int[] @default([0, 6])

  // Clock-in configurations
  allowedClockInMethods  ClockMethod[] @default([GPS, QR_CODE])
  requirePhoto           Boolean       @default(false)
  geofenceRadius         Float         @default(100)
  gracePeriodMinutes     Int           @default(5)
  earlyClockInMinutes    Int           @default(60)
  absencePenalty         Float?        @default(0)
  consecutiveLatePenalty Float?        @default(0)

  // Gambia statutory payroll (PAYE + SSN): when true, applied automatically for all employees
  gambiaStatutoryEnabled     Boolean              @default(false)
  employerSocialSecurityRate Float? // e.g. 10 for 10% (reporting only, not deducted from pay)
  gambiaSsnFundingMode       GambiaSsnFundingMode @default(DEDUCT_FROM_EMPLOYEE)

  // Gambia age-based PAYE exemption
  gambiaTaxAgeExemptionEnabled Boolean @default(false) // When true, use gambiaTaxExemptionAge to exempt older employees from PAYE
  gambiaTaxExemptionAge        Int? // Minimum age for PAYE exemption; null = no age-based exemption

  // Pay period governance: control creation of past pay periods
  allowPastPayPeriodCreation Boolean @default(true)
  maxPayPeriodLookbackDays   Int? // null = unlimited; e.g. 365 = max 12 months back

  users                User[]
  departments          Department[]
  positions            Position[]
  salaryStructures     SalaryStructure[]
  allowanceTypes       AllowanceType[]
  deductionTypes       DeductionType[]
  payPeriods           PayPeriod[]
  paySchedules         PaySchedule[]
  payrollRuns          PayrollRun[]
  calculationRules     CalculationRule[]
  auditLogs            AuditLog[]
  invitations          Invitation[]
  holidays             Holiday[]
  notifications        Notification[]
  recentActivities     RecentActivity[]
  employeeFeedItems    EmployeeFeedItem[]
  attendances          Attendance[]
  attendanceExceptions AttendanceException[]
  companyWorkDay       CompanyWorkDay?
  shifts               Shift[]
  locations            Location[]
  annualLeavePolicy    AnnualLeavePolicy?
  leaveTypes           LeaveType[]
  yearlyEntitlements   YearlyEntitlement[]
  leaveRequests        LeaveRequest[]
  patrolSites          PatrolSite[]
  patrolSchedules      PatrolSchedule[]
  batchJobs            BatchJob[]
  attendanceStatSnapshots AttendanceStatSnapshot[]

  @@index([phone])
  @@index([email])
  @@index([website])
}

model Department {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Manager relation
  managerId String?
  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)

  // Department fields
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Reverse relations
  employees   User[]
  invitations Invitation[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Position {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Position fields
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Reverse relations
  employees   User[]
  invitations Invitation[]

  @@unique([tenantId, title])
  @@index([tenantId])
}

model User {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Department relation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Position relation
  positionId String?
  position   Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  // Creator relation (for employee creation tracking)
  createdBy     String?
  createdByUser User?   @relation("UserCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdUsers  User[]  @relation("UserCreator")

  // Managed departments
  managedDepartments Department[]      @relation("DepartmentManager")
  salaryStructures   SalaryStructure[]
  processedPayrolls  PayrollRun[]      @relation("PayrollRunProcessor")
  payslips           Payslip[]

  // Authentication fields
  email           String
  password        String? // Better Auth - password (nullable, required for email/password auth)
  name            String? // Better Auth - display name (optional, can map to firstName)
  emailVerified   Boolean   @default(false) // Better Auth - email verified flag (boolean; use verifiedAt for timestamp if needed)
  image           String? // Better Auth - profile image URL (optional, can map to avatarUrl)
  dateOfBirth     DateTime?
  SSN             String?
  tinNumber       String?
  role            UserRole  @default(STAFF)
  isPlatformOwner Boolean   @default(false) // Only one SUPER_ADMIN should have this true (bootstrap owner)
  isDeleted       Boolean   @default(false)
  lastLogin       DateTime?

  // Employee fields (optional - not all users are employees)
  employeeId                     String
  gender                         Gender?            @default(PREFER_NOT_TO_SAY)
  phone                          String?
  hireDate                       DateTime?
  address                        String?
  addressLine1                   String?
  addressLine2                   String?
  emergencyContact               String?
  emergencyContactName           String?
  emergencyContactRelationship   String?
  emergencyContactPhone          String?
  emergencyContactPhoneSecondary String?
  status                         EmployeeStatus?    @default(ACTIVE)
  terminationReason              TerminationReason?
  employmentType                 EmploymentType?    @default(FULL_TIME)
  workLocation                   WorkLocation?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions                    Session[]
  accounts                    Account[]
  auditLogs                   AuditLog[]
  invitations                 Invitation[]
  notifications               Notification[]
  recentActivities            RecentActivity[]
  employeeFeedItems           EmployeeFeedItem[]
  attendances                 Attendance[]
  attendanceExceptions        AttendanceException[] @relation("AttendanceExceptionSubject")
  createdAttendanceExceptions AttendanceException[] @relation("AttendanceExceptionCreator")
  employeeWorkConfig          EmployeeWorkConfig?
  shiftId                     String?
  shift                       Shift?                @relation(fields: [shiftId], references: [id])
  yearlyEntitlements          YearlyEntitlement[]
  leaveRequests               LeaveRequest[]
  managedLeaveRequests        LeaveRequest[]        @relation("LeaveManager")
  hrLeaveRequests             LeaveRequest[]        @relation("LeaveHR")
  rejectedLeaveRequests       LeaveRequest[]        @relation("LeaveRejecter")
  patrolAssignments           PatrolSchedule[]      @relation("PatrolAssignee")
  patrolSessions              PatrolSession[]       @relation("PatrolSessionUser")
  patrolScanEvents            PatrolScanEvent[]     @relation("PatrolScanner")
  createdBatchJobs            BatchJob[]            @relation("BatchJobCreator")
  attendanceStatSnapshots     AttendanceStatSnapshot[]

  @@unique([tenantId, email])
  @@unique([tenantId, employeeId])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, positionId])
  @@index([tenantId, status])
  @@index([email])
  @@index([role])
  @@index([isDeleted])
  @@index([status])
  @@map("User")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ------------------------------------------------------------
// Payroll & Benefits Management
// ------------------------------------------------------------

model SalaryStructure {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Salary fields (baseSalary/grossSalary are in the period indicated by salaryPeriodType)
  baseSalary       Float            @default(0)
  grossSalary      Float            @default(0)
  salaryPeriodType SalaryPeriodType @default(MONTHLY)
  effectiveDate    DateTime
  endDate          DateTime?
  currency         String           @default("USD")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Reverse relations
  allowances Allowance[]
  deductions Deduction[]

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([userId, effectiveDate])
}

model AllowanceType {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  code        String
  description String?
  isTaxable   Boolean   @default(true)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Default calculation when this type is added to a salary structure (enterprise UX)
  defaultCalculationMethod CalculationMethod?
  defaultAmount            Float?
  defaultCalculationRuleId String?

  allowances       Allowance[]
  calculationRules CalculationRule[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Allowance {
  id String @id @default(uuid())

  // Salary Structure relation
  salaryStructureId String
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  // Allowance type relation
  allowanceTypeId String
  allowanceType   AllowanceType @relation(fields: [allowanceTypeId], references: [id], onDelete: Restrict)

  amount            Float             @default(0)
  amountPeriodType  SalaryPeriodType? @default(MONTHLY) // For FIXED only: amount is per this period
  calculationMethod CalculationMethod @default(FIXED)
  formulaExpression String? // Used when calculationMethod is FORMULA
  calculationRuleId String? // Optional reference to CalculationRule (for display/audit when FORMULA)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([salaryStructureId])
  @@index([allowanceTypeId])
}

model DeductionType {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  code        String
  description String?
  isStatutory Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Default calculation when this type is added to a salary structure (enterprise UX)
  defaultCalculationMethod CalculationMethod?
  defaultAmount            Float?
  defaultCalculationRuleId String?

  deductions       Deduction[]
  calculationRules CalculationRule[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Deduction {
  id String @id @default(uuid())

  // Salary Structure relation
  salaryStructureId String
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  // Deduction type relation
  deductionTypeId String
  deductionType   DeductionType @relation(fields: [deductionTypeId], references: [id], onDelete: Restrict)

  amount            Float             @default(0)
  amountPeriodType  SalaryPeriodType? @default(MONTHLY) // For FIXED only: amount is per this period
  calculationMethod CalculationMethod @default(FIXED)
  formulaExpression String? // Used when calculationMethod is FORMULA
  calculationRuleId String? // Optional reference to CalculationRule (for display/audit when FORMULA)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([salaryStructureId])
  @@index([deductionTypeId])
}

model CalculationRule {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Rule identification
  name        String
  description String?

  // Rule type and target
  ruleType        RuleType
  allowanceTypeId String?
  allowanceType   AllowanceType? @relation(fields: [allowanceTypeId], references: [id], onDelete: Restrict)
  deductionTypeId String?
  deductionType   DeductionType? @relation(fields: [deductionTypeId], references: [id], onDelete: Restrict)

  // Rule conditions (JSONB)
  conditions Json // Stores condition tree: {operator: "AND"|"OR", conditions: [...]}

  // Rule action (JSONB)
  action Json // Stores action: {type: "FIXED"|"PERCENTAGE"|"FORMULA", value: number, base: "baseSalary"|"grossSalary"}

  // Rule priority (higher = evaluated first)
  priority Int @default(0)

  // Rule status
  isActive Boolean @default(true)

  // Rule validity period
  effectiveDate DateTime
  endDate       DateTime?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, ruleType])
  @@index([allowanceTypeId])
  @@index([deductionTypeId])
}

model PaySchedule {
  id        String               @id @default(uuid())
  tenantId  String
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  frequency PayScheduleFrequency
  config    Json? // e.g. { "dates": [1, 15] } for semi-monthly, { "anchorDate": "2025-01-03" } for bi-weekly
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  deletedAt DateTime?

  payPeriods PayPeriod[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model PayPeriod {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Optional: which schedule generated this period
  payScheduleId String?
  paySchedule   PaySchedule? @relation(fields: [payScheduleId], references: [id], onDelete: SetNull)

  periodName      String
  startDate       DateTime
  endDate         DateTime
  calendarMonth   Int
  calendarYear    Int
  status          PayPeriodStatus @default(DRAFT)
  autoClosePaused Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  payrollRuns PayrollRun[]
  attendanceStatSnapshots AttendanceStatSnapshot[]

  @@unique([tenantId, periodName])
  @@index([tenantId])
  @@index([payScheduleId])
}

model AttendanceStatSnapshot {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payPeriodId String
  payPeriod   PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)

  periodStartDate DateTime
  periodEndDate   DateTime

  expectedWorkdays          Int @default(0)
  effectiveExpectedWorkdays Int @default(0)
  observedAttendanceDays    Int @default(0)

  presentCount        Int @default(0)
  lateCount           Int @default(0)
  absentCount         Int @default(0)
  excusedAbsenceCount Int @default(0)
  overtimeDaysCount   Int @default(0)
  overtimeHoursTotal  Float @default(0)
  expectedWorkHours   Float @default(0)

  presentRate  Float @default(0)
  lateRate     Float @default(0)
  absentRate   Float @default(0)
  overtimeRate Float @default(0)
  overtimeHoursRate Float @default(0)

  computedAt DateTime @default(now())
  computedBy String?

  @@unique([tenantId, userId, payPeriodId])
  @@index([tenantId, payPeriodId])
  @@index([tenantId, userId])
}

model PayrollRun {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Pay period relation
  payPeriodId String
  payPeriod   PayPeriod @relation(fields: [payPeriodId], references: [id], onDelete: Restrict)

  // Custom unique identifier (e.g., "PR-2025-001")
  runCode String?

  // Optional: when set, only these employees are processed when run is started (User ids)
  selectedEmployeeIds Json?

  runDate         DateTime         @default(now())
  totalEmployees  Int              @default(0)
  totalGrossPay   Float            @default(0)
  totalAllowances Float            @default(0)
  totalDeductions Float            @default(0)
  totalNetPay     Float            @default(0)
  status          PayrollRunStatus @default(DRAFT)
  processedBy     String?
  processedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // BullMQ job tracking
  queueJobId String?

  processor User?            @relation("PayrollRunProcessor", fields: [processedBy], references: [id], onDelete: SetNull)
  payslips  Payslip[]
  progress  PayrollProgress?

  @@unique([tenantId, runCode])
  @@index([tenantId])
  @@index([tenantId, payPeriodId])
  @@index([status, runDate])
  @@index([queueJobId])
  @@index([runCode])
}

model Payslip {
  id String @id @default(uuid())

  // Payroll run relation
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Salary values
  grossSalary     Float    @default(0)
  totalAllowances Float    @default(0)
  totalDeductions Float    @default(0)
  netSalary       Float    @default(0)
  filePath        String?
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  // Warning flags (for review by HR)
  hasWarnings Boolean @default(false)
  warnings    Json? // Stores warning details (e.g., negative net salary)

  // Snapshot of allowance/deduction breakdown at calculation time (so later config changes don't change past payslips)
  breakdownSnapshot Json? // { baseSalary, currency, allowances: [{ name, amount, calculationMethod, description }], deductions: [...] }

  // Application logic enforces one payslip per employee per run
  @@index([payrollRunId])
  @@index([userId])
  @@index([payrollRunId, userId])
}

model PayrollProgress {
  id                    String     @id @default(uuid())
  payrollRunId          String     @unique
  payrollRun            PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  totalEmployees        Int        @default(0)
  completedEmployees    Int        @default(0)
  failedEmployees       Int        @default(0)
  startedAt             DateTime   @default(now())
  estimatedCompletionAt DateTime?
  lastUpdatedAt         DateTime   @updatedAt

  @@index([payrollRunId])
}

// ------------------------------------------------------------
// Audit Trail Management and Notification System
// ------------------------------------------------------------

model AuditLog {
  id         String     @id @default(uuid())
  userId     String
  tenantId   String
  timestamp  DateTime   @default(now())
  action     ActionEnum
  entityType String
  entityId   String
  changes    Json?
  ipAddress  String?
  userAgent  String?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityId, entityType])
  @@index([timestamp])
}

// ------------------------------------------------------------
// Holiday & Working Days Management
// ------------------------------------------------------------

model Holiday {
  id          String      @id @default(uuid())
  tenantId    String
  name        String
  date        DateTime    @db.Date
  type        HolidayType @default(PUBLIC)
  description String?
  isRecurring Boolean     @default(false) // Repeats every year on same date
  year        Int? // If null and isRecurring=true, applies to all years
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, name]) // Prevent duplicate holidays
  @@index([tenantId, date])
  @@index([tenantId, year])
}

model Notification {
  id         Int              @id @default(autoincrement())
  tenantId   String
  userId     String
  title      String
  message    String
  type       NotificationType
  readStatus Boolean          @default(false)
  actionUrl  String?
  // Relations
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@index([readStatus])
  @@index([createdAt(sort: Desc)])
  @@map("notification")
}

enum NotificationType {
  PAYROLL
  ATTENDANCE
  LEAVE
  PERFORMANCE
  ACTIVITIES
  OTHER
  PATROL
}

// Recent activity feed (home screen, max 10 per request)
model RecentActivity {
  id          String             @id @default(cuid())
  tenantId    String
  userId      String
  type        RecentActivityType
  description String
  icon        String
  color       String
  createdAt   DateTime           @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([createdAt(sort: Desc)])
  @@map("recent_activity")
}

enum RecentActivityType {
  clock_in
  clock_out
  approved_leave
  rejected_leave
  leave_submitted
  payroll
  attendance
  other
}

/// Combined employee timeline (materialized for sync / reporting).
enum FeedItemKind {
  ATTENDANCE
  LEAVE
  HOLIDAY
  ATTENDANCE_EXCEPTION
}

enum FeedItemUiStatus {
  PENDING
  PRESENT
  ABSENT
  EXCUSED_ABSENCE
  HOLIDAY
}

model EmployeeFeedItem {
  id        String @id @default(uuid())
  tenantId  String
  userId    String
  kind      FeedItemKind
  uiStatus  FeedItemUiStatus
  sortAt    DateTime
  title     String
  detail    String
  sourceId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, kind, sourceId])
  @@index([tenantId, userId, sortAt(sort: Desc)])
  @@map("employee_feed_item")
}

// ------------------------------------------------------------
// Attendance, Workday, shift models
// ------------------------------------------------------------

model Attendance {
  id         String  @id @default(uuid())
  tenantId   String
  userId     String
  locationId String?

  clockInTime   DateTime?
  clockOutTime  DateTime?
  totalHours    Float?
  overtimeHours Float?    @default(0)

  status AttendanceStatus @default(ON_TIME)

  clockInMethod     ClockMethod?
  clockInPhotoUrl   String?
  clockInDeviceInfo String?
  clockInIpAddress  String?

  clockOutMethod     ClockMethod?
  clockOutDeviceInfo String?
  clockOutIpAddress  String?

  notes String?

  // relations

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, clockInTime])
  @@index([tenantId, clockInTime])
  @@index([locationId])
  @@index([status])
}

enum ClockMethod {
  GPS
  WIFI
  QR_CODE
  PHOTO
  MANUAL
}

enum AttendanceStatus {
  ON_TIME
  LATE
  EARLY
  ABSENT
}

enum AttendanceExceptionType {
  EXCUSED_ABSENCE
}

enum ExcusedAbsenceReasonCategory {
  MEDICAL
  FAMILY_EMERGENCY
  BEREAVEMENT
  TRANSPORT_DISRUPTION
  ADVERSE_WEATHER
  PUBLIC_DUTY
  APPROVED_LEAVE_OVERLAP
  SYSTEM_ISSUE
  ADMIN_CORRECTION
  OTHER
}

model AttendanceException {
  id String @id @default(cuid())

  tenantId String
  userId   String
  date     DateTime

  type AttendanceExceptionType @default(EXCUSED_ABSENCE)

  reasonCategory ExcusedAbsenceReasonCategory
  reason         String

  isActive    Boolean   @default(true)
  createdBy   String?
  clearedAt   DateTime?
  clearReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User   @relation("AttendanceExceptionSubject", fields: [userId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("AttendanceExceptionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, date])
  @@index([tenantId, date, type, isActive])
}

model EmployeeWorkConfig {
  id String @id @default(cuid())

  monday    Boolean @default(true)
  tuesday   Boolean @default(true)
  wednesday Boolean @default(true)
  thursday  Boolean @default(true)
  friday    Boolean @default(true)
  saturday  Boolean @default(false)
  sunday    Boolean @default(false)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CompanyWorkDay {
  id String @id @default(cuid())

  monday    Boolean @default(true)
  tuesday   Boolean @default(true)
  wednesday Boolean @default(true)
  thursday  Boolean @default(true)
  friday    Boolean @default(true)
  saturday  Boolean @default(false)
  sunday    Boolean @default(false)

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shift {
  id        String  @id @default(cuid())
  name      String  @default("Morning Shift")
  startTime String  @default("09:00")
  endTime   String  @default("17:00")
  isDefault Boolean @default(false)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  users User[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([isDefault])
}

model Location {
  id        String  @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  wifiSSID  String?
  isActive  Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ------------------------------------------------------------
// Leave Management
// ------------------------------------------------------------

model AnnualLeavePolicy {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Default allocation (can be overridden per employee)
  defaultDaysPerYear Float @default(21)

  // Accrual Configuration
  accrualMethod        AccrualMethod     @default(FRONT_LOADED)
  accrualFrequency     AccrualFrequency? // Only if accrualMethod = ACCRUAL
  accrualDaysPerPeriod Float? // Only if accrualMethod = ACCRUAL

  // Carryover Configuration
  carryoverType         CarryoverType @default(FULL)
  maxCarryoverDays      Float? // Only if carryoverType = LIMITED
  carryoverExpiryMonths Int? // Months after year-end when carryover expires
  encashmentRate        Float? // Rate per day if carryoverType = ENCASHMENT

  // Request Constraints
  advanceNoticeDays      Int     @default(0)
  requireManagerApproval Boolean @default(true) // true = two-tier (manager then HR), false = single-tier (HR only)

  // Recurring blackout (annual leave not allowed in this window every year). All four must be set for blackout to apply.
  blackoutStartMonth Int? // 1-12
  blackoutStartDay   Int? // 1-31
  blackoutEndMonth   Int? // 1-12
  blackoutEndDay     Int? // 1-31 (e.g. Dec 15 - Jan 15: 12, 15, 1, 15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  yearlyEntitlements YearlyEntitlement[]
}

model LeaveType {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String // "Annual Leave", "Sick Leave", "Study Leave"
  description String?
  color       String? // For calendar display

  // Behavior
  isPaid            Boolean @default(true)
  deductsFromAnnual Boolean @default(true) // Does this deduct from annual pool?
  requiresDocument  Boolean @default(false) // e.g., medical certificate

  // Status
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leaveRequests LeaveRequest[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model YearlyEntitlement {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  policyId String
  policy   AnnualLeavePolicy @relation(fields: [policyId], references: [id])

  year Int

  // Allocation
  allocatedDays   Float // From policy or overridden per employee
  accruedDays     Float @default(0) // Days accrued so far (if accrual method)
  carriedOverDays Float @default(0) // From previous year
  adjustmentDays  Float @default(0) // Manual adjustments (+/-)

  // Usage tracking
  usedDays    Float @default(0) // Approved leaves
  pendingDays Float @default(0) // Pending requests

  // Encashment tracking (if carryoverType = ENCASHMENT)
  encashedDays     Float @default(0)
  encashmentAmount Float @default(0)

  // Important dates
  yearStartDate       DateTime
  yearEndDate         DateTime
  lastAccrualDate     DateTime?
  carryoverExpiryDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, year])
  @@index([tenantId, userId])
  @@index([tenantId, year])
  @@index([userId, year])
  @@index([lastAccrualDate])
}

model LeaveRequest {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  // Request details
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  totalDays Float

  reason      String?
  attachments String[]

  // Status
  status LeaveRequestStatus @default(PENDING)

  // Two-Tier Approval: Manager then HR
  managerId         String?
  manager           User?     @relation("LeaveManager", fields: [managerId], references: [id], onDelete: SetNull)
  managerApprovedAt DateTime?

  hrId                     String?
  hr                       User?     @relation("LeaveHR", fields: [hrId], references: [id], onDelete: SetNull)
  hrApprovedAt             DateTime?
  hrApprovedWithoutManager Boolean? // true when HR approved from PENDING (override or single-tier)

  // Rejection
  rejectedBy      String?
  rejectedByUser  User?     @relation("LeaveRejecter", fields: [rejectedBy], references: [id], onDelete: SetNull)
  rejectedAt      DateTime?
  rejectionReason String?

  // Cancellation
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@index([userId, status])
  @@index([startDate, endDate])
  @@index([managerId, status])
  @@index([status])
  @@index([endDate]) // For leave-ending notifications
}

model BatchJob {
  id                 String         @id @default(uuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUserId    String
  createdByUser      User           @relation("BatchJobCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  type               BatchJobType
  status             BatchJobStatus @default(PENDING)
  batchCode          String
  originalFilename   String?
  fileSizeBytes      Int?
  inputJson          Json?
  failureReason      String?
  totalRows          Int            @default(0)
  processedCount     Int            @default(0)
  successCount       Int            @default(0)
  failedCount        Int            @default(0)
  processStartedAt   DateTime?
  processCompletedAt DateTime?
  queueJobId         String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  rows BatchJobRow[]

  @@unique([tenantId, batchCode])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model BatchJobRow {
  id             String            @id @default(uuid())
  batchJobId     String
  batchJob       BatchJob          @relation(fields: [batchJobId], references: [id], onDelete: Cascade)
  rowNumber      Int
  status         BatchJobRowStatus @default(PENDING)
  rawPayload     Json?
  errorMessage   String?
  errorField     String?
  resultEntityId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([batchJobId, rowNumber])
  @@index([batchJobId, status])
}

// ================================================
// PATROLS
// ================================================

enum PatrolSessionStatus {
  IN_PROGRESS
  COMPLETED
  INCOMPLETE // slot window closed, not all checkpoints hit
  MISSED // guard never scanned anything
}

model PatrolSite {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  checkpoints PatrolCheckpoint[]
  schedules   PatrolSchedule[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model PatrolCheckpoint {
  id           String     @id @default(uuid())
  patrolSiteId String
  patrolSite   PatrolSite @relation(fields: [patrolSiteId], references: [id], onDelete: Cascade)

  name        String
  description String?
  // Static token — encoded in printed QR code, never changes
  token       String   @unique @default(uuid())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scanEvents PatrolScanEvent[]

  @@index([patrolSiteId])
  @@index([token]) // critical — scan endpoint resolves by token
}

model PatrolSchedule {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patrolSiteId String
  patrolSite   PatrolSite @relation(fields: [patrolSiteId], references: [id], onDelete: Cascade)

  assignedUserId String
  assignedUser   User   @relation("PatrolAssignee", fields: [assignedUserId], references: [id], onDelete: Cascade)

  name            String // e.g. "Night Perimeter Round"
  intervalHours   Int    @default(2) // generate a new session every N hours
  windowStartTime String @default("08:00") // "HH:MM" — when first slot begins
  windowEndTime   String @default("20:00") // "HH:MM" — when slots stop

  // Compliance rule
  requireAllPoints Boolean @default(true) // false = guard only needs minCheckpoints
  minCheckpoints   Int? // only relevant if requireAllPoints = false

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions PatrolSession[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([assignedUserId])
  @@index([patrolSiteId])
}

model PatrolSession {
  id               String         @id @default(uuid())
  patrolScheduleId String
  patrolSchedule   PatrolSchedule @relation(fields: [patrolScheduleId], references: [id], onDelete: Cascade)

  assignedUserId String
  assignedUser   User   @relation("PatrolSessionUser", fields: [assignedUserId], references: [id], onDelete: Cascade)

  // The time window this session covers (e.g. 08:00–10:00)
  slotStart DateTime
  slotEnd   DateTime

  status           PatrolSessionStatus @default(IN_PROGRESS)
  // Denormalized counters — avoids aggregation on every list query
  checkpointsHit   Int                 @default(0)
  checkpointsTotal Int                 @default(0)

  startedAt   DateTime? // set on first scan
  completedAt DateTime? // set when checkpointsHit >= required

  intervalReminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scanEvents PatrolScanEvent[]

  @@unique([patrolScheduleId, slotStart]) // one session per schedule per slot
  @@index([patrolScheduleId])
  @@index([assignedUserId])
  @@index([status])
  @@index([slotStart, slotEnd])
  @@index([assignedUserId, slotStart])
}

model PatrolScanEvent {
  id              String        @id @default(uuid())
  patrolSessionId String
  patrolSession   PatrolSession @relation(fields: [patrolSessionId], references: [id], onDelete: Cascade)

  checkpointId String
  checkpoint   PatrolCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  scannedByUserId String
  scannedByUser   User   @relation("PatrolScanner", fields: [scannedByUserId], references: [id], onDelete: Cascade)

  scannedAt  DateTime @default(now())
  deviceInfo String?
  ipAddress  String?

  // Prevent duplicate scans of same checkpoint in same session
  @@unique([patrolSessionId, checkpointId])
  @@index([patrolSessionId])
  @@index([checkpointId])
  @@index([scannedByUserId])
  @@index([scannedAt])
}
