generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }

enum UserRole {
  HR_ADMIN
  HR_STAFF
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  TERMINATED
  RESIGNED
  ON_LEAVE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model Tenant {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  employees   Employee[]
  departments Department[]
}

model Department {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Manager relation
  managerId String?
  manager   Employee? @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)

  // Department fields
  code        String?
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Reverse relations
  employees Employee[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
}

model User {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Employee relation
  employeeId String?   @unique // link to Employee
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  // User fields
  email        String
  passwordHash String
  role         UserRole  @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Reverse relations
  createdEmployees Employee[] @relation("EmployeeCreator")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Employee {
  id String @id @default(uuid())

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Department relation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // User relation
  user User?

  // Creator relation
  createdBy     String?
  createdByUser User?   @relation("EmployeeCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  // Managed departments
  managedDepartments Department[] @relation("DepartmentManager")

  // Employee fields
  employeeId     String // business employee ID
  firstName      String
  lastName       String
  email          String?
  gender         Gender         @default(PREFER_NOT_TO_SAY)
  phone          String?
  hireDate       DateTime?
  jobTitle       String?
  avatarUrl      String?
  status         EmployeeStatus @default(ACTIVE)
  employmentType EmploymentType @default(FULL_TIME)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  @@unique([tenantId, employeeId])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, lastName])
  @@index([tenantId, status])
  @@index([email])
  @@index([status])
}
